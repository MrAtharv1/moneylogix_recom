# Copy this file, rename it to exactly '.env', and fill in your values
# DO NOT commit your actual .env file to GitHub!

# ---------------------------------------------------------
# AI ENGINE CONFIGURATION
# Options: "mock" (default, no key needed), "huggingface", or "claude"
# ---------------------------------------------------------
AI_PROVIDER=mock

# Required if AI_PROVIDER=huggingface (Free Serverless Inference API)
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here_xxxxxxxxx

# Required if AI_PROVIDER=claude (Anthropic API)
ANTHROPIC_API_KEY=sk-ant-your_claude_token_here_xxxxxxxxx

# ---------------------------------------------------------
# SYSTEM DEFAULTS (Leave these unless you need to tune performance)
# ---------------------------------------------------------
NSE_TIMEOUT_SECONDS=3
CACHE_TTL_SECONDS=60
HEALTH_MONITOR_INTERVAL_SECONDS=60
RISK_FREE_RATE=0.065
LOG_LEVEL=INFO